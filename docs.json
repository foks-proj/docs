      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/security",
              "concepts/federation"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/git",
              "cli/kv",
              "cli/team",
              "cli/device",
              "cli/yubikey",
              "cli/mcp",
              "cli/agent",
              "cli/bot"
            ]
          },
          {
            "group": "Self-Hosting",
            "pages": [
              "server/overview",
              "server/quickstart",
              "server/configuration",
              "server/virtual-hosts"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
